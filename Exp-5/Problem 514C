#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    vector<string> arr(n);

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    while(m--) {
        string s;
        cin >> s;

        bool found = false;

        for(string& t : arr) {

            if(t.size() != s.size())
                continue;

            int diff = 0;
            for(int i = 0; i < s.size(); i++) {
                if(s[i] != t[i])
                    diff++;

                if(diff > 1)
                    break;
            }
            if(diff == 1) {
                found = true;
                break;
            }
        }
        if(found){
            cout << "YES" << endl;
        }
        else{
            cout << "NO" << endl;
        }
    }
    return 0;
}